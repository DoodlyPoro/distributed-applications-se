@page "{id:int}"
@model FrontEnd.Pages.Pathways.DetailsModel

@{
    ViewData["Title"] = "Pathway Details";
}

<div class="container mt-5" style="max-width: 700px;">
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">

            <h2 class="fw-bold mb-2">Pathway Details</h2>
            <p class="text-muted mb-4">Read-only information about this pathway.</p>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger">@Model.Error</div>
            }
            else if (Model.Pathway != null)
            {
                <div class="mb-4">
                    <label class="text-muted small">Name</label>
                    <div class="fs-5 fw-semibold">@Model.Pathway.Name</div>
                </div>

                <div class="mb-4">
                    <label class="text-muted small">Description</label>
                    <div class="border rounded-3 p-3 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.Pathway.Description)
                            ? "No description"
                            : Model.Pathway.Description)
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between">
                <a asp-page="/Pathways/Index" class="btn btn-outline-secondary">Back</a>

                @if (Model.Pathway != null)
                {
                    <a asp-page="/Pathways/Edit"
                       asp-route-id="@Model.Pathway.Id"
                       class="btn btn-dark">
                        Edit
                    </a>
                }
            </div>

        </div>
    </div>
</div>