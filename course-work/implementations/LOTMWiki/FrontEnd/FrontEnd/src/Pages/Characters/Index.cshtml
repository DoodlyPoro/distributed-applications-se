@page
@model FrontEnd.Pages.Characters.IndexModel

@{
    ViewData["Title"] = "Characters";

    var totalPages = Model.Characters?.Pager == null || Model.Characters.Pager.PageSize == 0
        ? 0
        : (int)Math.Ceiling((double)Model.Characters.Pager.Count / Model.Characters.Pager.PageSize);
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold">Characters</h1>
            <p class="text-muted">Browse and manage characters.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/Index" class="btn btn-outline-secondary rounded-3">← Dashboard</a>
            <a asp-page="Create" class="btn btn-dark rounded-3">+ Create Character</a>
        </div>
    </div>

    <form method="get" class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label asp-for="Name" class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Search by name" />
                </div>

                <div class="col-md-3">
                    <label asp-for="Country" class="form-label">Country</label>
                    <input asp-for="Country" class="form-control" placeholder="Search by country" />
                </div>

                <div class="col-md-2">
                    <label asp-for="SequenceId" class="form-label">Sequence ID</label>
                    <input asp-for="SequenceId" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label asp-for="PathwayId" class="form-label">Pathway ID</label>
                    <input asp-for="PathwayId" class="form-control" />
                </div>

                <div class="col-md-2">
                    <label asp-for="EpochId" class="form-label">Epoch ID</label>
                    <input asp-for="EpochId" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label asp-for="OrderBy" class="form-label">Sort By</label>
                    <select asp-for="OrderBy" class="form-select">
                        <option value="Name">Name</option>
                        <option value="Country">Country</option>
                        <option value="SequenceId">Sequence</option>
                        <option value="PathwayId">Pathway</option>
                        <option value="EpochId">Epoch</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label asp-for="SortAsc" class="form-label">Direction</label>
                    <select asp-for="SortAsc" class="form-select">
                        <option value="true">Ascending</option>
                        <option value="false">Descending</option>
                    </select>
                </div>

                <input type="hidden" asp-for="PageSize" value="@Model.PageSize" />

                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
                    <button type="submit" class="btn btn-dark">Apply</button>
                </div>

            </div>
        </div>
    </form>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                <tr>
                    <th class="ps-4">Name</th>
                    <th>Country</th>
                    <th>Sequence</th>
                    <th>Pathway</th>
                    <th>Epoch</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
                </thead>

                <tbody>
                @if (Model.Characters?.Items != null && Model.Characters.Items.Any())
                {
                    @foreach (var item in Model.Characters.Items)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@item.Name</td>
                            <td>@item.Country</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.SequenceName))
                                {
                                    <span class="badge bg-primary">@item.SequenceName</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">None</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.PathwayName))
                                {
                                    <span class="badge bg-primary">@item.PathwayName</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">None</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.EpochName))
                                {
                                    <span class="badge bg-primary">@item.EpochName</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">None</span>
                                }
                            </td>

                            <td class="text-end pe-4">
                                <a asp-page="./Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary me-2">
                                    Edit
                                </a>

                                <a asp-page="./Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary me-2">
                                    Details
                                </a>

                                <form method="post"
                                      asp-page-handler="Delete"
                                      asp-route-id="@item.Id"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this character?');">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center p-5 text-muted">
                            No characters found.
                        </td>
                    </tr>
                }
                </tbody>
            </table>

        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted">
            Page @Model.Characters.Pager.Page of @totalPages
            — Total items: @Model.Characters.Pager.Count
        </div>

        <div>
            @if (Model.Characters.Pager.Page > 1)
            {
                <a class="btn btn-outline-dark me-2"
                   asp-page="./Index"
                   asp-route-PageNumber="@(Model.Characters.Pager.Page - 1)"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-Name="@Model.Name"
                   asp-route-Country="@Model.Country"
                   asp-route-SequenceId="@Model.SequenceId"
                   asp-route-PathwayId="@Model.PathwayId"
                   asp-route-EpochId="@Model.EpochId"
                   asp-route-OrderBy="@Model.OrderBy"
                   asp-route-SortAsc="@Model.SortAsc">
                    Previous
                </a>
            }

            @if (Model.Characters.Pager.Page < totalPages)
            {
                <a class="btn btn-dark"
                   asp-page="./Index"
                   asp-route-PageNumber="@(Model.Characters.Pager.Page + 1)"
                   asp-route-PageSize="@Model.PageSize"
                   asp-route-Name="@Model.Name"
                   asp-route-Country="@Model.Country"
                   asp-route-SequenceId="@Model.SequenceId"
                   asp-route-PathwayId="@Model.PathwayId"
                   asp-route-EpochId="@Model.EpochId"
                   asp-route-OrderBy="@Model.OrderBy"
                   asp-route-SortAsc="@Model.SortAsc">
                    Next
                </a>
            }
        </div>
    </div>
</div>