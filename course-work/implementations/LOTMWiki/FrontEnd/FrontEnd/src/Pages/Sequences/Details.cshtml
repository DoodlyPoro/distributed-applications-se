@page "{id:int}"
@model FrontEnd.Pages.Sequences.DetailsModel

@{
    ViewData["Title"] = "Sequence Details";
}

<div class="container mt-5" style="max-width: 700px;">
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">

            <h2 class="fw-bold mb-2">Sequence Details</h2>
            <p class="text-muted mb-4">Read-only information about this sequence.</p>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger">@Model.Error</div>
            }
            else if (Model.Sequence != null)
            {
                <div class="mb-4">
                    <label class="text-muted small">Number</label>
                    <div class="fs-5 fw-semibold">@Model.Sequence.Number</div>
                </div>

                <div class="mb-4">
                    <label class="text-muted small">Name</label>
                    <div class="fs-5 fw-semibold">@Model.Sequence.Name</div>
                </div>

                <div class="mb-4">
                    <label class="text-muted small">Description</label>
                    <div class="border rounded-3 p-3 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.Sequence.Description)
                            ? "No description"
                            : Model.Sequence.Description)
                    </div>
                </div>

                <div class="mb-4">
                    <label class="text-muted small">Pathway</label>
                    <div>
                        @if (Model.Sequence.PathwayName != null)
                        {
                            <span class="badge bg-primary">
                                @Model.Sequence.PathwayName
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">None</span>
                        }
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between">
                <a asp-page="/Sequences/Index" class="btn btn-outline-secondary">Back</a>

                @if (Model.Sequence != null)
                {
                    <a asp-page="/Sequences/Edit"
                       asp-route-id="@Model.Sequence.Id"
                       class="btn btn-dark">
                        Edit
                    </a>
                }
            </div>

        </div>
    </div>
</div>