@page
@model FrontEnd.Pages.Abilities.CreateModel

@{
    ViewData["Title"] = "Create Ability";
}

<div class="container mt-5" style="max-width: 650px;">

    <div class="card shadow border-0 rounded-4">

        <div class="card-body p-4">

            <h2 class="fw-bold mb-2">Create Ability</h2>

            <p class="text-muted mb-4">
                Add a new ability to the system.
            </p>

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Ability.Name" class="form-label"></label>
                    <input asp-for="Ability.Name" class="form-control" />
                    <span asp-validation-for="Ability.Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Ability.Description" class="form-label"></label>
                    <textarea asp-for="Ability.Description"
                              class="form-control"
                              rows="4"></textarea>
                    <span asp-validation-for="Ability.Description" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Ability.SequenceId" class="form-label">
                        Sequence ID
                    </label>
                    <input asp-for="Ability.SequenceId"
                           class="form-control"
                           placeholder="Optional" />
                    <div class="form-text">
                        Leave empty if this ability is not connected to a sequence.
                    </div>
                    <span asp-validation-for="Ability.SequenceId" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">

                    <a asp-page="/Abilities/Index"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit"
                            class="btn btn-dark">
                        Create
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}