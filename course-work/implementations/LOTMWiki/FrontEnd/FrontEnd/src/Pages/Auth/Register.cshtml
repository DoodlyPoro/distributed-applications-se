@page
@model FrontEnd.Pages.Auth.RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">

            <h2 class="fw-bold mb-4">Create Account</h2>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <div class="alert alert-danger">@Model.Error</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="User.Username" class="form-label"></label>
                    <input asp-for="User.Username" class="form-control" />
                    <span asp-validation-for="User.Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="User.Password" class="form-label"></label>
                    <input asp-for="User.Password"
                           type="password"
                           class="form-control" />
                    <span asp-validation-for="User.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="User.FirstName" class="form-label"></label>
                    <input asp-for="User.FirstName" class="form-control" />
                    <span asp-validation-for="User.FirstName" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="User.LastName" class="form-label"></label>
                    <input asp-for="User.LastName" class="form-control" />
                    <span asp-validation-for="User.LastName" class="text-danger"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="User.Age" class="form-label"></label>
                    <input asp-for="User.Age" class="form-control" />
                    <span asp-validation-for="User.Age" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-dark w-100">
                    Register
                </button>
            </form>

            <div class="mt-3 text-center">
                <a asp-page="/Auth/Login">Already have an account?</a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}