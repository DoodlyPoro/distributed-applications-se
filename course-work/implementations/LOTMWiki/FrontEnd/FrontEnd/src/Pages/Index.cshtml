@page
@model FrontEnd.Pages.IndexModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold">LOTMWiki Dashboard</h1>

            <p class="text-muted">
                Choose which table you want to manage.
            </p>
        </div>

        <form method="post" asp-page-handler="Logout">
            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-outline-danger">
                Logout
            </button>
        </form>

    </div>

    <div class="row g-4">
        
        <div class="col-md-4">
            <a asp-page="/Characters/Index" class="text-decoration-none text-dark">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Characters</h4>
                        <p class="text-muted">Manage character records.</p>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-4">
            <a asp-page="/Epochs/Index" class="text-decoration-none text-dark">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Epochs</h4>
                        <p class="text-muted">Manage epoch records.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-page="/Abilities/Index" class="text-decoration-none text-dark">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Abilities</h4>
                        <p class="text-muted">Manage ability records.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-page="/Sequences/Index" class="text-decoration-none text-dark">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Sequences</h4>
                        <p class="text-muted">Manage sequence records.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-page="/Pathways/Index" class="text-decoration-none text-dark">
                <div class="card shadow border-0 rounded-4 h-100">
                    <div class="card-body p-4">
                        <h4 class="fw-bold">Pathways</h4>
                        <p class="text-muted">Manage pathway records.</p>
                    </div>
                </div>
            </a>
        </div>

    </div>

</div>